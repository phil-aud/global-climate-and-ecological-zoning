function updateLabel(coords) {
  // Replace the label text with HLZ information
  
  var point = ee.Geometry.Point(coords.lon, coords.lat);
  
  // --- GCZ (NEW) ---
  gcz.reduceRegion(ee.Reducer.first(), point, 30).evaluate(function(result_gcz) {
    var value_gcz = result_gcz['remapped'];
    var labelName_gcz = labelMap_gcz[value_gcz];
  
  gez.reduceRegion(ee.Reducer.first(), point, 30).evaluate(function(result_gez) {
    var value_gez = result_gez['remapped'];
    var labelName_gez = labelMap_gez[value_gez];
    
    var value_gez_adj = result_gez['remapped'];
  
    if (value_gez_adj === 11) {
      value_gez_adj = '1a';
    } else if (value_gez_adj === 12) {
      value_gez_adj = '1b';
    } else if (value_gez_adj === 13) {
      value_gez_adj = '1c';
    } else if (value_gez_adj === 14) {
      value_gez_adj = '1d';
    } else if (value_gez_adj === 15) {
      value_gez_adj = '1e';
    } else if (value_gez_adj === 21) {
      value_gez_adj = '2a';
    } else if (value_gez_adj === 22) {
      value_gez_adj = '2b';
    } else if (value_gez_adj === 23) {
      value_gez_adj = '2c';
    } else if (value_gez_adj === 24) {
      value_gez_adj = '2d';
    } else if (value_gez_adj === 25) {
      value_gez_adj = '2e';
    } else if (value_gez_adj === 31) {
      value_gez_adj = '3a';
    } else if (value_gez_adj === 32) {
      value_gez_adj = '3b';
    } else if (value_gez_adj === 33) {
      value_gez_adj = '3c';
    } else if (value_gez_adj === 34) {
      value_gez_adj = '3d';
    } else if (value_gez_adj === 35) {
      value_gez_adj = '3e';
    } else if (value_gez_adj === 41) {
      value_gez_adj = '4a';
    } else if (value_gez_adj === 42) {
      value_gez_adj = '4b';
    } else if (value_gez_adj === 43) {
      value_gez_adj = '4c';
    } else if (value_gez_adj === 44) {
      value_gez_adj = '4d';
    } else if (value_gez_adj === 51) {
      value_gez_adj = '5a';
    } else if (value_gez_adj === 52) {
      value_gez_adj = '5b';
    } else if (value_gez_adj === 53) {
      value_gez_adj = '5c';
    } else if (value_gez_adj === 54) {
      value_gez_adj = '5d';
    } else if (value_gez_adj === 61) {
      value_gez_adj = '6a';
    } else if (value_gez_adj === 62) {
      value_gez_adj = '6b';
    } else if (value_gez_adj === 63) {
      value_gez_adj = '6c';
    } else if (value_gez_adj === 71) {
      value_gez_adj = '7a';
    } else {
      value_gez_adj = 'Unknown Value';
    }

    hlzII.reduceRegion(ee.Reducer.first(), point, 30).evaluate(function(result_hlzII) {
      var value_hlzII = result_hlzII['remapped'];
      var labelName_hlzII = labelMap_hlzII[value_hlzII];
      
      hlzIII.reduceRegion(ee.Reducer.first(), point, 30).evaluate(function(result_hlzIII) {
        var value_hlzIII = result_hlzIII['biotemperature'];
        var labelName_hlzIII = labelMap_hlzIII[value_hlzIII];
        
        gcz_label.setValue('GCZ: ' + labelName_gcz + ' (' + value_gcz + ')');
        gez_label.setValue('GEZ (HLZ - Level I): ' + labelName_gez + ' ('+ value_gez_adj + ')');
        hlzII_label.setValue('HLZ - Level II: ' + labelName_hlzII + ' ('+ value_hlzII + ')');
        hlzIII_label.setValue('HLZ - Level III: ' + labelName_hlzIII + ' ('+ value_hlzIII + ')');
      });
    });
  });
});
}

